# OIDC issuer / pod host. Defaults to the shared prod pod (SSO across siblings).
# For ordinary local dev with cross-app SSO, point at the shared Mind CSS
# (`docker compose up` at the workspace root; see ../SOLID-SERVER.md):
#   NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3011/
# To work the DID-linking workspace flow, shell runs its OWN two servers instead
# (stock :3101 + DID fork :3102 — see this repo's docker-compose.yml + AGENTS.md);
# the /connect dev-shortcut panel appears against a localhost issuer.
#   NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3101/
NEXT_PUBLIC_SOLID_ISSUER=https://pods.mindpods.org/

# Namespace this prototype claims under each user pod (the shell's own state).
NEXT_PUBLIC_SHELL_NAMESPACE=mind-shell

# Sibling app launcher URLs (inlined at build; fall back to local dev ports).
# NEXT_PUBLIC_APP_DOCK_URL=https://dock.mindpods.org
# NEXT_PUBLIC_APP_DRIVE_URL=https://drive.mindpods.org
# NEXT_PUBLIC_APP_BUILDER_URL=https://builder.mindpods.org
# NEXT_PUBLIC_APP_CODESPACES_URL=https://codespaces.mindpods.org
