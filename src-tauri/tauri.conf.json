{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mind-shell",
  "version": "0.1.0",
  "identifier": "org.mindpods.shell",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run export"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "mind-shell",
        "width": 1180,
        "height": 820,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "img-src": "'self' data: https:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "script-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost https://pod.mindpods.org https://api.pwnedpasswords.com http://localhost:3101",
        "frame-ancestors": "'none'",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Utility",
    "shortDescription": "Your pod's shell + zero-knowledge Vault.",
    "longDescription": "mind-shell is the Dock-style surface that wraps your Solid pod identity, hosting the zero-knowledge Vault password manager. Secrets are encrypted on-device by an audited Rust core; the pod stores only ciphertext.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "iOS": {
      "developmentTeam": "REPLACE_WITH_APPLE_TEAM_ID"
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [{ "host": "shell.mindpods.org", "pathPrefix": ["/auth/callback"] }],
      "desktop": {
        "schemes": ["org.mindpods.shell"]
      }
    }
  }
}
